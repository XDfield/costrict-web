# cs-user Configuration
# All vars use the CS_USER_ prefix. Required vars MUST be set; cs-user
# refuses to start if any of them is empty.

# ---------- HTTP ----------
# Listen port. Default 8081 to avoid clashing with @server (8080).
CS_USER_HTTP_PORT=8081
# gin mode: debug / release / test. Default debug.
CS_USER_HTTP_MODE=debug

# ---------- Postgres ----------
CS_USER_POSTGRES_HOST=localhost
CS_USER_POSTGRES_PORT=5432
CS_USER_POSTGRES_DATABASE=cs_user
# REQUIRED — cs-user refuses to start if empty.
CS_USER_POSTGRES_USER=postgres
# REQUIRED — cs-user refuses to start if empty.
CS_USER_POSTGRES_PASSWORD=change-me
# disable / require / verify-ca / verify-full. Default disable (dev).
CS_USER_POSTGRES_SSLMODE=disable

# ---------- Internal RPC shared secret ----------
# REQUIRED. Must match @server's CS_USER_RPC_INTERNAL_TOKEN. Authenticates
# the X-Internal-Token header on /api/internal/* endpoints. Generate with:
#   openssl rand -hex 32
CS_USER_INTERNAL_TOKEN=dev-internal-secret-change-me

# ---------- JWT signing (cs-user as issuer, Phase A) ----------
# PKCS#1 ("RSA PRIVATE KEY") or PKCS#8 ("PRIVATE KEY") PEM file path.
# OPTIONAL at boot — when empty, JWKS endpoint returns 503 and the A7
# reissue-token flow is disabled. Production MUST set this.
# Generate with:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out cs-user/testdata/jwt.pem
CS_USER_JWT_SIGNING_KEY_PATH=./testdata/jwt.pem
# iss claim on cs-user-issued tokens. Default "cs-user"; set to cs-user's
# public base URL when relying parties need to verify iss against a known origin.
CS_USER_JWT_ISSUER=cs-user
# Token TTL (Go duration syntax: "1h", "30m", "3600s"). Default 1h.
CS_USER_JWT_TTL=1h
# Comma-separated aud claim values applied when caller doesn't override.
# Empty = no aud claim (relying parties that require aud will reject).
# Default unset; populate in production, e.g. "costrict-cloud,gitea-fork".
CS_USER_JWT_AUDIENCE=costrict-cloud

# ---------- Tenant resolution (Phase B3b) ----------
# Comma-separated apex domains the deployment serves. Used by subdomain
# fallback to extract slug from request Host. Examples:
#   - prod:  CS_USER_APEX_DOMAINS=cs-user.example.com,cs-user.example.cn
#   - dev:   CS_USER_APEX_DOMAINS=localhost:8082
# Empty (default) disables subdomain resolution — middleware falls through
# to cookie / X-Tenant-Id / default tenant row.
CS_USER_APEX_DOMAINS=

# Gitea auto-provisioning has no env config — git_servers are managed via
# /api/internal/git-servers (and bound per-tenant via
# /api/internal/tenants/:id/git-server). Tenants without a bound git_server
# are soft-skipped at provision time. See
# docs/repo-management/REPOSITORY_MANAGEMENT_SPEC.md.

# ---------- Dev-mode auto-migrate ----------
# When truthy ("1" / "true" / "yes" — case-insensitive), cs-user runs all
# pending migrations on boot. Use in dev only; prod runs migrations out-of-band
# via `migrate` binary or k8s init container.
CS_USER_AUTO_MIGRATE=1

# ---------- Git Ownership Refactor Phase 2: event outbox ----------
# When CS_USER_EVENT_TARGET_URL is empty, the outbox is disabled entirely
# (user.Service skips the publish path). Set it to server's consumer URL
# to emit user.created events; the server-side worker picks them up and
# provisions Git server accounts locally (Git Ownership Refactor Phase 4
# removed the cs-user → Gitea path; cs-user only emits events now).
#
# The token MUST match @server's INTERNAL_SECRET (same one that gates
# other /api/internal/* routes). Mismatch → 403 → event retried with
# backoff, eventually moved to 'failed' after MaxAttempts.
CS_USER_EVENT_TARGET_URL=
CS_USER_EVENT_TARGET_TOKEN=
# Optional tuning (defaults shown):
# CS_USER_EVENT_POLL_INTERVAL=1s
# CS_USER_EVENT_BATCH_SIZE=50
# CS_USER_EVENT_MAX_ATTEMPTS=0        # 0 = unlimited
# CS_USER_EVENT_BACKOFF_BASE=2s
# CS_USER_EVENT_BACKOFF_MAX=5m
# CS_USER_EVENT_HTTP_TIMEOUT=5s
