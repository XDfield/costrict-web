# 本地开发覆盖配置：复制为 .env.local，并被 server 自动加载。
# 这里只列出"和 .env.example 默认值不同 / 本地特有"的变量；其余按需要补。

# ---- Casdoor (本地 docker-compose 起的 casdoor) ----
# 主机直接 go run 时：宿主机访问 docker 暴露的 8000 端口
CASDOOR_ENDPOINT=http://localhost:8000
# 这两个值与 casdoor/init_data.json 中预置的 costrict-local application 一致
CASDOOR_CLIENT_ID=costrict-local-client-id
CASDOOR_CLIENT_SECRET=costrict-local-client-secret-do-not-use-in-prod
# init_data.json 把 application 放在 built-in 组织下；与 server 默认值不同
CASDOOR_ORGANIZATION=built-in
# 默认回调指向 server 自己；前端会动态传 callback_url 覆盖
CASDOOR_CALLBACK_URL=http://localhost:8080/api/auth/callback

# ---- 其他本地友好的覆盖 ----
COOKIE_SECURE=false
FRONTEND_URLS=http://localhost:3000,http://127.0.0.1:3000
