{
  "name": "costrict-web",
  "version": "0.1.0",
  "private": true,
  "description": "AI Agent Platform - Integrating Casdoor and buildwithclaude",
  "scripts": {
    "dev:server": "cd server && go run main.go",
    "dev:web": "cd web/web-ui && npm run dev",
    "dev": "concurrently \"npm run dev:server\" \"npm run dev:web\"",
    "build:server": "cd server && go build -o bin/server main.go",
    "docker:up": "docker-compose up -d",
    "docker:down": "docker-compose down",
    "docker:logs": "docker-compose logs -f"
  },
  "devDependencies": {
    "concurrently": "^8.2.2"
  }
}
