# Database
DATABASE_URL=postgres://costrict:costrict_password@localhost:5432/costrict_db?sslmode=disable

# Casdoor
CASDOOR_ENDPOINT=http://localhost:8000
CASDOOR_CLIENT_ID=your-client-id
CASDOOR_CLIENT_SECRET=your-client-secret
CASDOOR_ORG_NAME=built-in
CASDOOR_APP_NAME=app-built-in
CASDOOR_CALLBACK_URL=http://localhost:8080/api/auth/callback

# NextAuth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=your-secret-key-here

# Application
NODE_ENV=development

# Server
PORT=8080

# LLM Configuration (GLM with OpenAI protocol)
LLM_PROVIDER=openai
LLM_API_KEY=your-glm-api-key
LLM_MODEL=glm-4-plus
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Embedding Configuration (GLM Embedding)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-glm-api-key
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=1024

# Search Configuration
SEARCH_DEFAULT_LIMIT=20
SEARCH_SIMILARITY_THRESHOLD=0.7

# Storage Configuration
ARTIFACT_STORAGE_PATH=./data/artifacts

# Redis
REDIS_URL=redis://localhost:6379
