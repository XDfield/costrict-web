# Server Configuration
PORT=8080
DATABASE_URL=postgres://costrict:costrict_password@localhost:5432/costrict_db?sslmode=disable
REDIS_URL=redis://localhost:6379
COSTRICT_CLOUD_BASE_URL=https://app.costrict.ai

# Usage Provider Configuration
# Supported values: sqlite, es
USAGE_PROVIDER=sqlite
USAGE_SQLITE_PATH=./data/usage/usage.db
USAGE_ES_REPORT_BASE_URL=
USAGE_ES_QUERY_BASE_URL=
USAGE_ES_REPORT_PATH=/internal/indicator/api/v1/session_turn_metrics
USAGE_ES_QUERY_PATH=/costrict_session_turn_metrics/_search
USAGE_ES_TIMEOUT_SECONDS=15
# Optional Basic Auth credentials for ES indicator service requests
USAGE_ES_BASIC_USER=
USAGE_ES_BASIC_PASS=
# Optional: skip TLS certificate verification for ES usage requests
USAGE_ES_INSECURE_SKIP_VERIFY=false
# Allowed frontend origins (comma-separated). First entry is the default fallback.
# The frontend dynamically passes its origin at login; only listed origins are accepted.
# Add each developer's local address as needed.
FRONTEND_URLS=http://localhost:3000

# Internal API (gateway <-> server shared secret, must match gateway INTERNAL_SECRET)
INTERNAL_SECRET=your-internal-secret-change-me

# System token for simple API authentication (e.g. release creation via X-System-Token header)
SYSTEM_TOKEN=

# Bootstrap platform administrators (comma-separated Casdoor universal_id values,
# CASE-SENSITIVE — values are whitespace-trimmed but NOT lowercased). A user is
# granted platform_admin only when they themselves verify-login and their
# universal_id matches an entry here — use this to seed the FIRST administrator
# without manual SQL. Idempotent and best-effort (never blocks login). A user's
# universal_id is shown in the admin member list (each row's universalId field).
# After the first admin is in, grant further roles via the admin console and
# remove/keep this as you see fit. Empty = no-op.
BOOTSTRAP_PLATFORM_ADMIN_UNIVERSAL_IDS=

# Security
# Set to false for local development over HTTP; defaults to true for production (HTTPS only cookies)
COOKIE_SECURE=false
# Comma-separated list of allowed CORS origins; leave empty to allow all (dev only)
# CORS_ALLOWED_ORIGINS=https://app.costrict.ai,https://costrict.ai

# Casdoor Authentication
CASDOOR_ENDPOINT=http://localhost:8000
# Internal endpoint for server-to-server calls (token exchange, userinfo).
# Set this to the K8s service URL when CASDOOR_ENDPOINT is a public URL that the pod cannot resolve.
# Falls back to CASDOOR_ENDPOINT if not set.
# CASDOOR_INTERNAL_ENDPOINT=http://casdoor-svc:8000
CASDOOR_CLIENT_ID=your-client-id
CASDOOR_CLIENT_SECRET=your-client-secret
# Default OAuth callback URL (fallback when the frontend does not provide callback_url).
# At runtime the frontend dynamically passes its own origin as callback_url so that
# Casdoor redirects back through the frontend host and Set-Cookie lands on the correct domain.
# Register all possible callback URLs (backend + each frontend origin) in Casdoor.
CASDOOR_CALLBACK_URL=http://localhost:8080/api/auth/callback

# LLM Configuration (GLM with OpenAI protocol)
LLM_PROVIDER=openai
LLM_API_KEY=your-glm-api-key
LLM_MODEL=glm-4-plus
LLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4
LLM_MAX_TOKENS=4096
LLM_TEMPERATURE=0.7

# Embedding Configuration (GLM Embedding)
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=your-glm-api-key
EMBEDDING_MODEL=embedding-3
EMBEDDING_BASE_URL=https://open.bigmodel.cn/api/paas/v4
EMBEDDING_DIMENSIONS=1024

# Search Configuration
SEARCH_DEFAULT_LIMIT=20
SEARCH_SIMILARITY_THRESHOLD=0.7

# Channel Configuration
# System-level availability controls for notification channels.
# Platform administrators must first enable and configure channel types before users can use them.
# Each channel type has independent enable flags below.
# Set to false to disable a channel type system-wide (users won't see it as an option).
# CHANNEL_ENABLED_TYPES is deprecated; use individual flags below instead.

# WeChat Work (企业微信) App Notifications - requires system admin configuration
CHANNEL_WECOM_ENABLED=true
# WeChat Work (企业微信) Group Bot Webhooks
CHANNEL_WECOM_WEBHOOK_ENABLED=true
# WeChat (微信) Login and Messaging
CHANNEL_WECHAT_ENABLED=true

# Notification Buffer Configuration
# Duration (in seconds) to buffer interactive events (permission, question) before sending notifications.
# This allows time for users to respond via web UI before sending IM notifications.
# Set to 0 to send notifications immediately without buffering.
# Default: 60 seconds
NOTIFICATION_BUFFER_SECONDS=60

# WeCom (企业微信) System Configuration
# These are the bot-level credentials configured by the system admin.
# Users only need to provide their employee ID (userId) when setting up the channel.
WECOM_CORP_ID=
WECOM_AGENT_ID=0
WECOM_SECRET=
WECOM_TOKEN=
WECOM_ENCODING_AES_KEY=

# Storage Configuration
ARTIFACT_STORAGE_PATH=./data/artifacts

# Security Scan Configuration
SCAN_ENABLED=true
SCAN_LLM_MODEL=glm-4-plus
SCAN_LLM_TIMEOUT_SECONDS=30
SCAN_LLM_MAX_INPUT_TOKENS=6000
SCAN_WORKER_CONCURRENCY=2
