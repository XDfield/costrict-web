# Proxy Configuration

# Listen address (default: :8090)
LISTEN_ADDR=:8090

# Upstream server URL (default: http://server:8080)
SERVER_URL=http://localhost:8080

# PostgreSQL connection string for audit logs (required)
DATABASE_URL=postgres://costrict:costrict_password@localhost:5432/costrict_audit?sslmode=disable

# Database connection pool
DB_MAX_OPEN_CONNS=10
DB_MAX_IDLE_CONNS=5
DB_CONN_MAX_LIFETIME=300

# Audit log retention in days (default: 90)
AUDIT_RETENTION_DAYS=90

# Filter rules YAML file path (default: ./filter_rules.yaml)
FILTER_RULES_PATH=./filter_rules.yaml

# Max response body size to intercept (bytes, default: 50MB)
MAX_INTERCEPT_BODY_SIZE=52428800

# Filter failure mode: "block" (default) or "passthrough"
# block = return 502 on filter error; passthrough = forward unfiltered
FILTER_FAILURE_MODE=block

# Audit worker settings
AUDIT_CHANNEL_SIZE=4096
AUDIT_BATCH_SIZE=100
AUDIT_FLUSH_INTERVAL_MS=5000
AUDIT_SEND_TIMEOUT=5

# Log level: debug, info, warn, error (default: info)
LOG_LEVEL=info

# Graceful shutdown timeout in seconds (default: 30)
SHUTDOWN_TIMEOUT=30
